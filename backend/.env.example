# FastAPI Configuration
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/joblens

# LLM Configuration
# Provider: "ollama" | "freemodel" | "openai"
LLM_PROVIDER=ollama

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
MODEL_NAME=llama3

# FreeModel.dev (used when LLM_PROVIDER=freemodel)
# FREEMODEL_API_KEY=
# FREEMODEL_BASE_URL=https://api.freemodel.dev/v1
# FREEMODEL_MODEL=auto

# Aggregator API keys
# Adzuna: free tier keys at https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=in
DEFAULT_JOB_LOCATION=

ADZUNA_ENABLED=true
REMOTIVE_ENABLED=true
ARBEITNOW_ENABLED=true

# Minimum minutes between resume-driven live searches (debounce for free-tier API quotas)
LIVE_SEARCH_MIN_INTERVAL_MINUTES=15

# Redis — connection is built from individual components (not REDIS_URL) to
# avoid python-dotenv's unreliable ${VAR} interpolation inside .env files.
# All four vars are required when running via docker-compose; the compose
# file will fail to start if REDIS_PASSWORD is unset.
REDIS_PASSWORD=changeme            # REQUIRED — must match docker-compose value
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# SMTP Configuration
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@joblens.ai

# WhatsApp Configuration
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Notification settings
MAX_NOTIFS_PER_HOUR=5

# Frontend URL — used for CORS allowed origins and notification deep-links.
# Supports comma-separated values for multi-origin setups:
#   FRONTEND_URL=http://localhost:5173,https://joblens.example.com
FRONTEND_URL=http://localhost:5173

# Top N matches to generate rationales for
TOP_N_RATIONALES=10